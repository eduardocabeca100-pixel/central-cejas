# ============================================
# Configurações de Supabase (Banco de Dados)
# ============================================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role
SUPABASE_ANON_KEY=sua_chave_anon_ou_publishable
SUPABASE_STORAGE_BUCKET=servidor-cejas

# ============================================
# Segurança
# ============================================
SESSION_SECRET=uma_chave_secreta_muito_segura_e_aleatoria
ADMIN_EMAIL=admin@cejas.com.br
ADMIN_PASSWORD_HASH=hash_bcrypt_da_senha

# ============================================
# Ambiente
# ============================================
NODE_ENV=development
PORT=5500

# ============================================
# Configurações Opcionais
# ============================================
# CEJAS_PERSISTENT_DATA_DIR=/opt/render/project/src/uploads/.data
# DEBUG=true
# LOG_LEVEL=info
